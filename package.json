{
  "name": "js_hands_up_trigger",
  "version": "1.0.0",
  "description": "A Node.js script that triggers a shell command when a \"hand up\" gesture is detected in an NDI video stream, using TensorFlow.js and Google's MoveNet SinglePose Lightning model.",
  "type": "module",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jake-gregory/js_hands_up_trigger.git"
  },
  "homepage": "https://github.com/jake-gregory/js_hands_up_trigger#readme",
  "bugs": {
    "url": "https://github.com/jake-gregory/js_hands_up_trigger/issues"
  },
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.19.5"
  },
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "keywords": [
    "ndi",
    "movenet",
    "pose-detection",
    "tensorflow",
    "gesture",
    "live-streaming",
    "applescript",
    "mevo"
  ],
  "author": "Jake Gregory",
  "license": "MIT",
  "dependencies": {
    "@tensorflow-models/pose-detection": "^2.1.3",
    "@tensorflow/tfjs-converter": "^4.22.0",
    "@tensorflow/tfjs-core": "^4.22.0",
    "@tensorflow/tfjs-node": "^4.22.0",
    "grandi": "^1.3.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/eslint-plugin": "^1.1.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.0",
    "globals": "^15.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
